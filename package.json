{
  "name": "dr_agent",
  "version": "1.0.0",
  "description": "[中文版本 (README_ZH.md)](README_ZH.md)",
  "main": "index.js",
  "scripts": {
    "test": "hardhat test",
    "test:contracts": "hardhat test",
    "test:baseline": "python3 scripts/test_baseline.py",
    "test:api": "python3 -m pytest -q tests/test_api_flow.py",
    "setup:api": "bash scripts/setup_python_env.sh api",
    "setup:python": "bash scripts/setup_python_env.sh full",
    "smoke:api": "python3 scripts/smoke_api_flow.py",
    "frontend:serve": "python3 -m http.server 4173 --directory frontend",
    "demo:walkthrough": "bash scripts/demo_walkthrough.sh",
    "demo:walkthrough:live": "DR_CHAIN_MODE=fuji-live DR_TX_CONFIRM_MODE=hybrid DR_DEMO_SITE_MODE=dual bash scripts/demo_walkthrough.sh",
    "deploy:fuji": "bash scripts/run_with_secrets.sh ./node_modules/.bin/hardhat run scripts/deploy_fuji.ts --network fuji",
    "deploy:fuji:raw": "./node_modules/.bin/hardhat run scripts/deploy_fuji.ts --network fuji",
    "deploy:fuji:settlement": "bash scripts/run_with_secrets.sh ./node_modules/.bin/hardhat run scripts/redeploy_settlement_fuji.ts --network fuji",
    "deploy:fuji:settlement:evidence": "npm run deploy:fuji:settlement && npm run evidence:execution",
    "deploy:fuji:drt": "bash scripts/run_with_secrets.sh ./node_modules/.bin/hardhat run scripts/deploy_drt_fuji.ts --network fuji",
    "evidence:execution": "python3 scripts/build_execution_evidence_bundle.py",
    "evidence:execution:drt": "python3 scripts/build_drt_evidence_bundle.py",
    "evidence:judge": "npm run evidence:execution",
    "evidence:judge:drt": "npm run evidence:execution:drt",
    "deploy:fuji:drt:evidence": "npm run deploy:fuji:drt && npm run evidence:execution:drt",
    "deploy:bridge:fuji": "bash scripts/run_with_secrets.sh ./node_modules/.bin/hardhat run scripts/deploy_bridge_fuji.ts --network fuji",
    "deploy:bridge:l1": "bash scripts/run_with_secrets.sh ./node_modules/.bin/hardhat run scripts/deploy_bridge_l1.ts --network dr_l1",
    "bridge:action": "node scripts/bridge_chain_action.js",
    "icm:action": "node scripts/icm_chain_action.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AIEnergyBlockchain/DR-Agent.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AIEnergyBlockchain/DR-Agent/issues"
  },
  "homepage": "https://github.com/AIEnergyBlockchain/DR-Agent#readme",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "5.0.0",
    "hardhat": "2.28.6"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0"
  }
}
