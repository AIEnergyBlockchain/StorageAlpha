# 安全建议：
# - 不要在工作区保留真实 .env，建议使用工作区外 secrets 文件：
#   ~/.config/dr-agent/secrets.env
# - 可执行：make secrets-init && make secrets-check
# - 启动命令请优先使用：make api-run / make demo-run / make deploy-fuji
#
# 说明（API 密钥）：
# 1) 这些 API 密钥是本项目自定义的鉴权口令，不是第三方平台申请的 token。
# 2) 获取方式：由你在本地/服务器环境变量中自行设置（可先用默认值）。
# 3) 生产或公开演示建议使用随机强口令，例如：
#    openssl rand -hex 16
# 4) 调用 API 时需在请求头传入 x-api-key（并配合 x-actor-id）。

# DR_OPERATOR_API_KEY：Operator 角色的 API 密钥。
# 必要性：本地演示与脚本调用都必需；不配置会导致创建/关闭事件、触发结算鉴权失败。
DR_OPERATOR_API_KEY=operator-key

# DR_PARTICIPANT_API_KEY：Participant 角色的 API 密钥。
# 必要性：本地演示与脚本调用都必需；不配置会导致提交 proof、领取奖励鉴权失败。
DR_PARTICIPANT_API_KEY=participant-key

# DR_AUDITOR_API_KEY：Auditor 角色的 API 密钥。
# 必要性：审计与查询流程建议配置；不配置会影响 /events 只读查询与 /audit 审计查询。
DR_AUDITOR_API_KEY=auditor-key

# DR_CORS_ORIGINS：允许跨域访问 API 的前端来源（逗号分隔）。
# 必要性：仅当前端与 API 跨域时必需；本地默认值已覆盖常见开发地址，可按需修改。
DR_CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173

# DR_CHAIN_MODE：链执行模式。可选 simulated / fuji-live（或 fuji）。
# 必要性：若要现场演示真实上链，必须设为 fuji-live（并配置 PRIVATE_KEY + 部署地址文件）。
DR_CHAIN_MODE=simulated

# DR_TX_CONFIRM_MODE：链上确认模式。可选 hybrid / sync。
# 必要性：非必需；默认 hybrid（秒回 tx_hash + 异步回填确认/手续费），sync 会每步等待链上确认。
DR_TX_CONFIRM_MODE=hybrid

# DR_DEMO_SITE_MODE：演示站点模式。可选 dual / single。
# 必要性：非必需；默认 dual（完整双站点闭环），若现场预算紧张可临时切 single 降耗。
DR_DEMO_SITE_MODE=dual

# DR_REQUIRED_SITES：可选，覆盖默认 proof 站点（逗号分隔，如 site-a,site-b）。
# 必要性：非必需；仅在你需要自定义“必须提交 proof 的站点集合”时配置。
DR_REQUIRED_SITES=site-a,site-b

# DR_AGENT_DB：本地 SQLite 数据库文件路径。
# 必要性：非必需；不配置会使用默认路径，建议在多环境下显式指定以避免数据混用。
DR_AGENT_DB=cache/dr_agent.db

# DR_FUJI_RPC_URL：Fuji JSON-RPC 地址。
# 必要性：非必需；不配置则使用默认官方 RPC，网络不稳定时可替换为你自己的 RPC 服务。
DR_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# FUJI_RPC_URL：Bridge/ICM 实际链上操作使用的 Fuji RPC（ops 脚本读取）。
# 必要性：非必需；缺省时使用 DR_FUJI_RPC_URL 或官方默认 RPC。
FUJI_RPC_URL=

# DR_L1_RPC_URL：Custom DR-L1 RPC 地址（ops 脚本读取）。
# 必要性：执行 DR-L1 部署、绑定、ICM/Bridge 链上动作时必需。
DR_L1_RPC_URL=

# PRIVATE_KEY：Fuji 钱包私钥（不要提交真实私钥到仓库）。
# 必要性：执行 `DR_CHAIN_MODE=fuji-live` 真实上链演示、或执行 Bridge/ICM 部署与链上动作时必需。
PRIVATE_KEY=

# DR_DEPLOY_OUT：Fuji 部署结果 JSON 输出路径。
# 必要性：非必需；不配置会写入默认路径，建议在 CI/多环境中显式配置以便归档。
DR_DEPLOY_OUT=cache/fuji-deployment-latest.json

# DR_FUJI_DEPLOY_OUT：Fuji 主合约部署输出（Bridge 部署会读取 drt_token）。
# 必要性：仅在 Bridge Home 部署时使用；默认 cache/fuji-deployment-latest.json。
DR_FUJI_DEPLOY_OUT=cache/fuji-deployment-latest.json

# DRT_TOKEN_ADDRESS：Bridge Home 部署时的 DRT 代币地址（可选，覆盖 DR_FUJI_DEPLOY_OUT）。
DRT_TOKEN_ADDRESS=

# DR_BRIDGE_RELAYER：Bridge/ICM relayer 地址（可选，默认 deployer）。
DR_BRIDGE_RELAYER=

# DR_BRIDGE_FUJI_OUT：Fuji Bridge 部署输出路径。
DR_BRIDGE_FUJI_OUT=cache/fuji-bridge-deployment-latest.json

# DR_BRIDGE_L1_OUT：DR-L1 Bridge/ICM 部署输出路径。
DR_BRIDGE_L1_OUT=cache/l1-bridge-deployment-latest.json

# DR_BRIDGE_REMOTE_CHAIN / DR_BRIDGE_REMOTE_ADDRESS：Fuji 部署时可选直接绑定 remote。
DR_BRIDGE_REMOTE_CHAIN=
DR_BRIDGE_REMOTE_ADDRESS=

# DR_BRIDGE_HOME_CHAIN / DR_BRIDGE_HOME_ADDRESS：DR-L1 部署时可选直接绑定 home。
DR_BRIDGE_HOME_CHAIN=
DR_BRIDGE_HOME_ADDRESS=

# BRIDGE_RPC_URL / BRIDGE_DEPLOY_OUT：bridge_chain_action.js 使用的 RPC 与部署输出。
BRIDGE_RPC_URL=
BRIDGE_DEPLOY_OUT=

# ICM_RPC_URL / ICM_DEPLOY_OUT：icm_chain_action.js 使用的 RPC 与部署输出。
ICM_RPC_URL=
ICM_DEPLOY_OUT=

# FUJI_CHAIN_LABEL / DR_L1_CHAIN_LABEL：ops 脚本用于计算 chain_id bytes32（可选）。
FUJI_CHAIN_LABEL=fuji
DR_L1_CHAIN_LABEL=dr-l1

# FUJI_CHAIN_ID_BYTES32 / DR_L1_CHAIN_ID_BYTES32：如已知 bytes32，可直接填写覆盖 label 计算。
FUJI_CHAIN_ID_BYTES32=
DR_L1_CHAIN_ID_BYTES32=

# Bridge/ICM 实际链上动作参数（ops 脚本可选）
BRIDGE_SEND_AMOUNT_WEI=1000000000000000000
BRIDGE_RECEIVE_AMOUNT_WEI=1000000000000000000
BRIDGE_RECIPIENT=
BRIDGE_SOURCE_NONCE=

ICM_MESSAGE_ID=
ICM_MESSAGE_TYPE=bridge_transfer
ICM_SENDER=
ICM_SOURCE_CHAIN_LABEL=fuji
ICM_SOURCE_CHAIN_ID_BYTES32=
ICM_PAYLOAD_JSON={"amount":"1000"}
ICM_SUCCESS=true

# ops 执行控制
CONFIRM=
STEPS=
EVIDENCE_DIR=

# DR_TX_OUT_DIR：demo_walkthrough 输出 tx 汇总与原始响应文件目录。
# 必要性：非必需；默认 cache，可用于快速定位现场演示生成的 tx hash。
DR_TX_OUT_DIR=cache
